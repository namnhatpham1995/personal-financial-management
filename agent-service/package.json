{
  "name": "fintrack-agent-service",
  "version": "0.1.0",
  "private": true,
  "description": "LangGraph.js receipt ingestion agent: extract -> categorize -> validate -> interrupt (human review) -> commit, on behalf of the Fintrack backend.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@langchain/anthropic": "^0.3.14",
    "@langchain/core": "^0.3.40",
    "@langchain/langgraph": "^0.2.44",
    "@langchain/langgraph-checkpoint-postgres": "^0.0.4",
    "axios": "^1.7.9",
    "express": "^4.21.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.4",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.20.0",
    "pg": "^8.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^1.6.1"
  }
}
