{
  "name": "fintrack-mcp-server",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server exposing Fintrack accounts, transactions, budgets, and analytics to MCP clients via a scoped Personal Access Token.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "fintrack-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.7.9",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^1.6.1"
  }
}
