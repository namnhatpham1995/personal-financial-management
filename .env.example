# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/fintrack
DB_USERNAME=fintrack
DB_PASSWORD=fintrack

# ── Database (MongoDB — audit log) ────────────────────────────────────────────
# Local dev (no auth): mongodb://localhost:27017/fintrack_audit
# Railway: append database name + authSource=admin to the MONGO_URL Railway provides:
#   mongodb://<MONGOUSER>:<MONGOPASSWORD>@<MONGOHOST>:27017/fintrack_audit?authSource=admin
SPRING_DATA_MONGODB_URI=mongodb://localhost:27017/fintrack_audit

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 256 bits (32 chars). Generate with: openssl rand -base64 64
JWT_SECRET=change-this-to-a-long-random-secret-in-production
# Browser session inactivity and absolute lifetime (24 hours / 30 days)
JWT_SESSION_IDLE_TIMEOUT_MS=86400000
JWT_SESSION_ABSOLUTE_TIMEOUT_MS=2592000000

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=local

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_AUTH=10

# ── Redis (cache backend — required in prod, optional locally) ─────────────────
# Railway: set to ${{Redis.REDIS_URL}} from the Railway Redis plugin
# Local docker: redis://localhost:6379 (docker-compose sets this automatically)
# Leave unset locally when using simple in-process cache (no Redis needed)
SPRING_DATA_REDIS_URL=redis://localhost:6379

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
